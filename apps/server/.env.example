# `make env-init` copies this file to .env and fills the JWT secret if needed
# NEVER commit .env to git

APP_ENV=development
SERVER_PORT=8080

# PostgreSQL
DATABASE_URL=postgres://phantom:phantom@localhost:5433/phantom?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-random-32-char-secret
JWT_EXPIRY=15m
# Refresh token lifetime: 30 days
REFRESH_TOKEN_EXPIRY=720h
